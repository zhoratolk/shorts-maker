work/
# work/_profile/ specifically holds style_profile.py's output, derived from
# real per-channel titles/stats (youtube_analytics.py cache) - never track it,
# even though work/ above already covers it (explicit privacy boundary).
__pycache__/
*.pyc
*.egg-info/
.venv/
config.yaml
# .claude/ is machine-local (settings, worktrees) EXCEPT the make-shorts
# skill, which is tracked so a fresh clone gets /make-shorts working with
# zero setup steps.
.claude/*
!.claude/skills
.claude/skills/*
!.claude/skills/make-shorts
.superpowers/
.planning/.tmp-*
.planning/research/.cache/
client_secret.json
token.json
upload_token.json
tiktok_client_key.json
tiktok_token.json
tiktok_oauth_cert.pem
tiktok_oauth_key.pem
instagram_client_secret.json
instagram_token.json
# Rotated/revoked credential backups (e.g. token.json.revoked-YYYY-MM-DD,
# upload_token.json.expired-YYYY-MM-DD) - same secrets, must never be tracked.
*token*.revoked-*
*token*.expired-*
*.json.revoked-*
*.json.expired-*
.pytest_cache/
# .pytest-tmp/ is this machine's --basetemp override for pytest's tmp_path
# fixture - the default OS temp dir is permission-locked here (see
# STATE.md Blockers/Concerns), so tests are run with --basetemp pointing
# at this repo-local scratch dir instead. Runtime output only, never tracked.
.pytest-tmp/
.pytest_tmp/
