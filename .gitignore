work/
# work/_profile/ specifically holds style_profile.py's output, derived from
# real per-channel titles/stats (youtube_analytics.py cache) - never track it,
# even though work/ above already covers it (explicit privacy boundary).
__pycache__/
*.pyc
.venv/
config.yaml
.claude/
client_secret.json
token.json
upload_token.json
tiktok_client_key.json
tiktok_token.json
instagram_client_secret.json
instagram_token.json
.pytest_cache/
# .pytest-tmp/ is this machine's --basetemp override for pytest's tmp_path
# fixture - the default OS temp dir is permission-locked here (see
# STATE.md Blockers/Concerns), so tests are run with --basetemp pointing
# at this repo-local scratch dir instead. Runtime output only, never tracked.
.pytest-tmp/
